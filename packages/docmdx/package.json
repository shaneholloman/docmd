{
  "name": "docmdx",
  "version": "0.6.9",
  "description": "Run docmd instantly. Zero setup, zero config.",
  "type": "module",
  "type": "module",
  "main": "bin/docmdx.js",
  "bin": {
    "docmdx": "bin/docmdx.js"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "build": "tsc && chmod +x bin/docmdx.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@docmd/core": "workspace:*"
  },
  "keywords": [
    "docmd",
    "documentation",
    "markdown",
    "zero-config",
    "static-site-generator"
  ],
  "author": "Ghazi Khan (mgks.dev)",
  "license": "MIT",
  "homepage": "https://docmd.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/docmd-io/docmd",
    "directory": "packages/docmdx"
  }
}