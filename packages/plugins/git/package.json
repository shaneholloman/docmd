{
  "name": "@docmd/plugin-git",
  "version": "0.8.13",
  "description": "Git integration plugin for docmd.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "docmd": {
    "key": "git",
    "kind": "plugin",
    "displayName": "Git",
    "tagline": "Git integration with last-updated timestamps and commit history.",
    "capabilities": [
      "init",
      "build",
      "body",
      "assets",
      "post-build",
      "translations"
    ]
  },
  "scripts": {
    "build": "tsc && node build.js"
  },
  "files": [
    "dist",
    "i18n"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@docmd/api": "workspace:*"
  },
  "devDependencies": {
    "@docmd/api": "workspace:*",
    "@types/node": "^24.13.3"
  },
  "keywords": [
    "docmd",
    "plugin",
    "git",
    "github",
    "gitlab",
    "last-updated",
    "contributors",
    "edit-link",
    "markdown",
    "documentation",
    "minimalist",
    "zero-config",
    "site-generator",
    "static-site-generator",
    "docs"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd/issues"
  },
  "homepage": "https://docmd.io",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}