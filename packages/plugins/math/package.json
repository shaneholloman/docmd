{
  "name": "@docmd/plugin-math",
  "version": "0.8.11",
  "description": "Mathematics (KaTeX/LaTeX) plugin for docmd.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "docmd": {
    "key": "math",
    "kind": "plugin",
    "displayName": "Math",
    "tagline": "Mathematics (KaTeX/LaTeX) plugin for docmd.",
    "capabilities": [
      "markdown",
      "assets"
    ]
  },
