{
  "name": "@docmd/plugin-sitemap",
  "version": "0.8.12",
  "description": "Sitemap generator plugin for docmd.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "docmd": {
    "key": "sitemap",
    "kind": "plugin",
    "displayName": "Sitemap",
    "tagline": "Sitemap generator for docmd.",
    "capabilities": [
      "post-build"
    ]
  },
  "scripts": {
    "build": "tsc"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@docmd/api": "workspace:*",
    "@types/node": "^24.13.3"
  },
  "keywords": [
    "docmd",
    "plugin",
    "sitemap",
    "xml",
    "url",
    "seo",
    "markdown",
    "minimalist",
    "zero-config",
    "site-generator",
    "static-site-generator",
    "docs"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd/issues"
  },
  "homepage": "https://docmd.io",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}