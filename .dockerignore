# Dependencies (will be installed fresh in builder)
node_modules
**/node_modules

# Build outputs (will be built in builder)
*.tsbuildinfo
packages/*/dist
packages/plugins/*/dist
packages/engines/*/dist

# Generated sites
packages/*/site
packages/_playground/site

# Test and playground
packages/_playground

# Development files
.git
.github
.vscode
.idea
.DS_Store

# Native build artifacts
packages/engines/rust-binaries/native/target

# Top-level docs (not package source)
docs
demo
docmd.io

# Logs and temp
*.log
temp-*
tmp
temp

# Environment files
.env
.env.*
!.env.example

# Test files
coverage
.nyc_output

# Misc
*.tgz
*.bak